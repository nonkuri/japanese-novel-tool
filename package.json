{
  "name": "japanese-novel-tool",
  "version": "0.1.3",
  "description": "Obsidian plugin for Japanese novel indentation, ruby/emphasis rendering, and character counting.",
  "main": "main.js",
  "scripts": {
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "test": "node test/parser.test.mjs"
  },
  "keywords": [
    "obsidian",
    "japanese",
    "novel",
    "ruby",
    "character-count"
  ],
  "license": "MIT",
  "devDependencies": {
    "@codemirror/language": "6.11.0",
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.38.6",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.21.5",
    "obsidian": "1.13.0",
    "typescript": "^5.9.3"
  }
}
